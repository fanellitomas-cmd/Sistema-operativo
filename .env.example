# Copiá este archivo a .env y completá los valores

# API Key de Anthropic (obtené una en https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Secreto para firmar los tokens JWT (generá uno largo y aleatorio)
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio

# Puerto del servidor (opcional, default: 3000)
PORT=3000

# Ruta al archivo de base de datos SQLite (opcional, default: ./boreal.db)
DB_PATH=./boreal.db
